# ==========================================
# FeedCrafter - Environment Variables Template
# ==========================================

# Database Configuration (PostgreSQL & Prisma)
DATABASE_URL="postgresql://feedcrafter:feedcrafter_pass@localhost:5432/feedcrafter_db?schema=public"

# Redis Configuration (BullMQ & Cache)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Google Gemini AI API Key (@google/genai)
GEMINI_API_KEY="your_gemini_api_key_here"

# Discord Integration
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"

# Twitch / IGDB API Integration
TWITCH_CLIENT_ID="your_twitch_client_id"
TWITCH_CLIENT_SECRET="your_twitch_client_secret"

# Service Ports & Host configuration
PORT_BACKEND=4000
PORT_FRONTEND=3000
FRONTEND_URL="http://localhost:3000"

# Application Environment
NODE_ENV="development"
JWT_SECRET="super_secret_jwt_key_change_me_in_production"
